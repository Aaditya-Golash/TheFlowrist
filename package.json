{
  "name": "theflowrist",
  "version": "1.0.0",
  "description": "Production-ready starter for TheFlowrist",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "seed": "node -e \"require('./lib/seed').writeSeedData(); console.log('Seed data written')\"",
    "reset:data": "node -e \"require('./lib/seed').resetData(); console.log('Data reset complete')\"",
    "check:supabase": "node scripts/check-supabase.js",
    "migrate:supabase": "node scripts/migrate-json-to-supabase.js",
    "smoke:supabase": "node scripts/smoke-supabase.js",
    "test": "node --test",
    "predeploy:check": "npm test && npm run check:supabase"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.0",
    "ws": "^8.21.0"
  }
}
